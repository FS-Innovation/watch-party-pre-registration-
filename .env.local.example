# === REQUIRED: Supabase ===
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === REQUIRED: Email (Resend) ===
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_ADDRESS=DOAC <tickets@yourdomain.com>

# === OPTIONAL: SMS (Twilio) — for magic link delivery ===
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# === OPTIONAL: AI Clustering (Anthropic) ===
ANTHROPIC_API_KEY=your_anthropic_api_key

# === OPTIONAL: Analytics (Rudderstack) ===
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your_rudderstack_write_key
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=your_rudderstack_data_plane_url

# === OPTIONAL: Admin ===
ADMIN_SECRET=your_admin_secret

# === OPTIONAL: App URL (for magic links) ===
NEXT_PUBLIC_APP_URL=https://your-app-url.com
